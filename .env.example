# =============================================================================
# Compliance App — Environment Variables
# =============================================================================
# Copy this file to .env (already git-ignored by Create React App)
# and fill in your real values. Never commit the actual .env file.
# =============================================================================

# Base URL for all API calls (no trailing slash)
REACT_APP_API_BASE_URL=https://api.yourcompany.com/api

# Request timeout in milliseconds (default: 30000)
REACT_APP_API_TIMEOUT=30000

# Endpoint used by the Axios service to refresh the access token
REACT_APP_REFRESH_ENDPOINT=/auth/token/refresh/

# Application version — injected into X-Client-Version request header
REACT_APP_VERSION=1.0.0
